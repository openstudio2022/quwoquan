# 趣我圈App 状态管理与错误处理规范

## 🔄 Riverpod状态管理规范

### 状态类设计

```dart
// ✅ 状态类必须不可变
class HomeState {
  final bool isLoading;
  final List<Post> posts;
  final String? error;
  final int currentPage;
  final bool hasMore;
  
  const HomeState({
    required this.isLoading,
    required this.posts,
    this.error,
    required this.currentPage,
    required this.hasMore,
  });
  
  // ✅ 必须提供copyWith方法
  HomeState copyWith({
    bool? isLoading,
    List<Post>? posts,
    String? error,
    int? currentPage,
    bool? hasMore,
  }) {
    return HomeState(
      isLoading: isLoading ?? this.isLoading,
      posts: posts ?? this.posts,
      error: error ?? this.error,
      currentPage: currentPage ?? this.currentPage,
      hasMore: hasMore ?? this.hasMore,
    );
  }
  
  // ✅ 提供相等性比较
  @override
  bool operator ==(Object other) {
    if (identical(this, other)) return true;
    return other is HomeState &&
        other.isLoading == isLoading &&
        listEquals(other.posts, posts) &&
        other.error == error &&
        other.currentPage == currentPage &&
        other.hasMore == hasMore;
  }
  
  @override
  int get hashCode {
    return isLoading.hashCode ^
        posts.hashCode ^
        error.hashCode ^
        currentPage.hashCode ^
        hasMore.hashCode;
  }
}
```

### StateNotifier实现

```dart
// ✅ 使用StateNotifier进行复杂状态管理
class HomeNotifier extends StateNotifier<HomeState> {
  final PostService _postService;
  
  HomeNotifier(this._postService) : super(const HomeState(
    isLoading: false,
    posts: [],
    currentPage: 1,
    hasMore: true,
  ));
  
  // ✅ 异步操作必须有完整的错误处理
  Future<void> loadPosts() async {
    // 防止重复加载
    if (state.isLoading) return;
    
    try {
      state = state.copyWith(isLoading: true, error: null);
      
      final posts = await _postService.getPosts(page: state.currentPage);
      
      state = state.copyWith(
        isLoading: false,
        posts: [...state.posts, ...posts],
        currentPage: state.currentPage + 1,
        hasMore: posts.isNotEmpty,
      );
    } catch (e) {
      state = state.copyWith(
        isLoading: false,
        error: _getErrorMessage(e),
      );
    }
  }
  
  Future<void> refreshPosts() async {
    try {
      // 重置状态
      state = const HomeState(
        isLoading: true,
        posts: [],
        currentPage: 1,
        hasMore: true,
      );
      
      await loadPosts();
    } catch (e) {
      state = state.copyWith(
        isLoading: false,
        error: _getErrorMessage(e),
      );
    }
  }
  
  void clearError() {
    state = state.copyWith(error: null);
  }
  
  String _getErrorMessage(Object error) {
    if (error is NetworkException) {
      return error.message;
    } else if (error is ValidationException) {
      return error.message;
    } else {
      return UITextConstants.errorOccurred;
    }
  }
}

// ✅ Provider定义
final homeProvider = StateNotifierProvider<HomeNotifier, HomeState>((ref) {
  final postService = ref.watch(postServiceProvider);
  return HomeNotifier(postService);
});
```

### Provider使用规范

```dart
// ✅ 在Widget中正确使用Provider
class HomePage extends ConsumerWidget {
  const HomePage({Key? key}) : super(key: key);
  
  @override
  Widget build(BuildContext context, WidgetRef ref) {
    // ✅ 使用watch监听状态变化
    final homeState = ref.watch(homeProvider);
    
    // ✅ 使用read执行操作（不监听）
    final homeNotifier = ref.read(homeProvider.notifier);
    
    // ✅ 使用listen处理副作用
    ref.listen<HomeState>(
      homeProvider,
      (previous, next) {
        // 显示错误提示
        if (next.error != null) {
          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(
              content: Text(next.error!),
              backgroundColor: AppColors.error,
            ),
          );
        }
      },
    );
    
    return Scaffold(
      appBar: AppBar(
        title: Text(UITextConstants.home),
      ),
      body: _buildBody(homeState, homeNotifier),
    );
  }
  
  Widget _buildBody(HomeState state, HomeNotifier notifier) {
    // 加载状态
    if (state.isLoading && state.posts.isEmpty) {
      return const LoadingWidget();
    }
    
    // 空状态
    if (state.posts.isEmpty) {
      return EmptyWidget(
        message: UITextConstants.noData,
        onRetry: notifier.loadPosts,
      );
    }
    
    // 数据展示
    return RefreshIndicator(
      onRefresh: notifier.refreshPosts,
      child: ListView.builder(
        itemCount: state.posts.length + (state.hasMore ? 1 : 0),
        itemBuilder: (context, index) {
          if (index == state.posts.length) {
            return const LoadingWidget();
          }
          return PostCard(post: state.posts[index]);
        },
      ),
    );
  }
}

// ✅ 使用select优化性能
class PostCounter extends ConsumerWidget {
  const PostCounter({Key? key}) : super(key: key);
  
  @override
  Widget build(BuildContext context, WidgetRef ref) {
    // 只监听posts的长度变化，不监听整个state
    final count = ref.watch(
      homeProvider.select((state) => state.posts.length),
    );
    
    return Text('${UITextConstants.total}: $count');
  }
}
```

## 🚨 错误处理规范

### 自定义异常类

```dart
// ✅ 定义清晰的异常层次
abstract class AppException implements Exception {
  final String message;
  final String? code;
  final dynamic data;
  
  const AppException(this.message, {this.code, this.data});
  
  @override
  String toString() => 'AppException: $message';
}

// 网络异常
class NetworkException extends AppException {
  const NetworkException(String message, {String? code}) 
      : super(message, code: code ?? 'NETWORK_ERROR');
}

// 验证异常
class ValidationException extends AppException {
  const ValidationException(String message, {dynamic data}) 
      : super(message, code: 'VALIDATION_ERROR', data: data);
}

// 认证异常
class AuthenticationException extends AppException {
  const AuthenticationException(String message) 
      : super(message, code: 'AUTH_ERROR');
}

// 业务异常
class BusinessException extends AppException {
  const BusinessException(String message, {String? code, dynamic data}) 
      : super(message, code: code ?? 'BUSINESS_ERROR', data: data);
}

// 未找到异常
class NotFoundException extends AppException {
  const NotFoundException(String message) 
      : super(message, code: 'NOT_FOUND');
}
```

### 统一错误处理

```dart
// ✅ 统一错误处理器
class ErrorHandler {
  static void handleError(
    Object error,
    StackTrace stackTrace, {
    BuildContext? context,
  }) {
    // 记录错误日志
    Logger.error('Error occurred: $error', stackTrace);
    
    // 发送错误报告
    AnalyticsService.logError(error, stackTrace);
    
    // 根据错误类型处理
    if (error is NetworkException) {
      _handleNetworkError(error, context);
    } else if (error is ValidationException) {
      _handleValidationError(error, context);
    } else if (error is AuthenticationException) {
      _handleAuthError(error, context);
    } else if (error is BusinessException) {
      _handleBusinessError(error, context);
    } else {
      _handleUnknownError(error, context);
    }
  }
  
  static void _handleNetworkError(
    NetworkException error,
    BuildContext? context,
  ) {
    Logger.warning('Network error: ${error.message}');
    
    if (context != null && context.mounted) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(error.message),
          backgroundColor: AppColors.error,
          action: SnackBarAction(
            label: UITextConstants.retry,
            textColor: AppColors.light.textPrimary,
            onPressed: () {
              // 重试逻辑
            },
          ),
        ),
      );
    }
  }
  
  static void _handleValidationError(
    ValidationException error,
    BuildContext? context,
  ) {
    Logger.info('Validation error: ${error.message}');
    
    if (context != null && context.mounted) {
      showDialog(
        context: context,
        builder: (context) => AlertDialog(
          title: Text(UITextConstants.validationError),
          content: Text(error.message),
          actions: [
            TextButton(
              onPressed: () => Navigator.of(context).pop(),
              child: Text(UITextConstants.ok),
            ),
          ],
        ),
      );
    }
  }
  
  static void _handleAuthError(
    AuthenticationException error,
    BuildContext? context,
  ) {
    Logger.error('Auth error: ${error.message}');
    
    // 清除认证信息
    // 跳转到登录页面
    if (context != null && context.mounted) {
      Navigator.of(context).pushReplacementNamed('/login');
    }
  }
  
  static void _handleBusinessError(
    BusinessException error,
    BuildContext? context,
  ) {
    Logger.warning('Business error: ${error.message}');
    
    if (context != null && context.mounted) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(error.message),
          backgroundColor: AppColors.warning,
        ),
      );
    }
  }
  
  static void _handleUnknownError(
    Object error,
    BuildContext? context,
  ) {
    Logger.error('Unknown error: $error');
    
    if (context != null && context.mounted) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(UITextConstants.errorOccurred),
          backgroundColor: AppColors.error,
        ),
      );
    }
  }
}
```

### 异步操作错误处理

```dart
// ✅ Service层错误处理
class PostService {
  final Dio _dio;
  
  PostService(this._dio);
  
  Future<List<Post>> getPosts({int page = 1}) async {
    try {
      final response = await _dio.get(
        '/posts',
        queryParameters: {'page': page},
      );
      
      if (response.statusCode == 200) {
        final data = response.data;
        return (data['posts'] as List)
            .map((json) => Post.fromJson(json))
            .toList();
      } else {
        throw NetworkException(
          'Failed to load posts: ${response.statusCode}',
          code: 'HTTP_${response.statusCode}',
        );
      }
    } on DioException catch (e) {
      // 处理Dio异常
      if (e.type == DioExceptionType.connectionTimeout) {
        throw const NetworkException('Connection timeout');
      } else if (e.type == DioExceptionType.receiveTimeout) {
        throw const NetworkException('Receive timeout');
      } else if (e.type == DioExceptionType.connectionError) {
        throw const NetworkException('No internet connection');
      } else if (e.response?.statusCode == 401) {
        throw const AuthenticationException('Unauthorized');
      } else if (e.response?.statusCode == 404) {
        throw const NotFoundException('Posts not found');
      } else {
        throw NetworkException('Network error: ${e.message}');
      }
    } on FormatException {
      throw const NetworkException('Invalid response format');
    } catch (e) {
      if (e is AppException) {
        rethrow;
      }
      throw NetworkException('Unexpected error: $e');
    }
  }
}
```

## 🔐 安全编码规范

### 输入验证

```dart
// ✅ 输入验证器
class InputValidator {
  // Email验证
  static String? validateEmail(String? value) {
    if (value == null || value.isEmpty) {
      return UITextConstants.emailRequired;
    }
    
    final emailRegex = RegExp(r'^[\w-\.]+@([\w-]+\.)+[\w-]{2,4}$');
    if (!emailRegex.hasMatch(value)) {
      return UITextConstants.emailInvalid;
    }
    
    return null;
  }
  
  // 密码验证
  static String? validatePassword(String? value) {
    if (value == null || value.isEmpty) {
      return UITextConstants.passwordRequired;
    }
    
    if (value.length < 8) {
      return UITextConstants.passwordTooShort;
    }
    
    if (!RegExp(r'[A-Z]').hasMatch(value)) {
      return UITextConstants.passwordNeedsUppercase;
    }
    
    if (!RegExp(r'[a-z]').hasMatch(value)) {
      return UITextConstants.passwordNeedsLowercase;
    }
    
    if (!RegExp(r'[0-9]').hasMatch(value)) {
      return UITextConstants.passwordNeedsNumber;
    }
    
    return null;
  }
  
  // 手机号验证
  static String? validatePhone(String? value) {
    if (value == null || value.isEmpty) {
      return UITextConstants.phoneRequired;
    }
    
    final phoneRegex = RegExp(r'^\+?[1-9]\d{1,14}$');
    if (!phoneRegex.hasMatch(value)) {
      return UITextConstants.phoneInvalid;
    }
    
    return null;
  }
  
  // 用户名验证
  static String? validateUsername(String? value) {
    if (value == null || value.isEmpty) {
      return UITextConstants.usernameRequired;
    }
    
    if (value.length < 3 || value.length > 20) {
      return UITextConstants.usernameLength;
    }
    
    final usernameRegex = RegExp(r'^[a-zA-Z0-9_]+$');
    if (!usernameRegex.hasMatch(value)) {
      return UITextConstants.usernameInvalid;
    }
    
    return null;
  }
}
```

### 敏感数据处理

```dart
// ✅ 安全存储
class SecureStorage {
  static const _storage = FlutterSecureStorage(
    aOptions: AndroidOptions(
      encryptedSharedPreferences: true,
    ),
    iOptions: IOSOptions(
      accessibility: KeychainAccessibility.first_unlock_this_device,
    ),
  );
  
  // 存储Token
  static Future<void> storeToken(String token) async {
    await _storage.write(key: 'auth_token', value: token);
  }
  
  // 获取Token
  static Future<String?> getToken() async {
    return await _storage.read(key: 'auth_token');
  }
  
  // 删除Token
  static Future<void> deleteToken() async {
    await _storage.delete(key: 'auth_token');
  }
  
  // 清除所有数据
  static Future<void> clearAll() async {
    await _storage.deleteAll();
  }
}

// ✅ 数据脱敏
class DataMasker {
  // 邮箱脱敏
  static String maskEmail(String email) {
    final parts = email.split('@');
    if (parts.length != 2) return email;
    
    final username = parts[0];
    final domain = parts[1];
    
    if (username.length <= 2) return email;
    
    final maskedUsername = username[0] + 
        '*' * (username.length - 2) + 
        username[username.length - 1];
    
    return '$maskedUsername@$domain';
  }
  
  // 手机号脱敏
  static String maskPhone(String phone) {
    if (phone.length < 7) return phone;
    
    return phone.substring(0, 3) + 
        '****' + 
        phone.substring(phone.length - 4);
  }
  
  // 身份证号脱敏
  static String maskIdCard(String idCard) {
    if (idCard.length < 10) return idCard;
    
    return idCard.substring(0, 6) + 
        '********' + 
        idCard.substring(idCard.length - 4);
  }
}
