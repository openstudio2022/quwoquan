{
  "dashboard": {
    "title": "L3 — 服务黄金信号",
    "uid": "qwq-l3-golden",
    "tags": ["quwoquan", "l3", "golden-signals"],
    "timezone": "browser",
    "refresh": "30s",
    "templating": {
      "list": [
        {
          "name": "service",
          "type": "query",
          "query": "label_values(http_server_requests_total, service)",
          "refresh": 2
        }
      ]
    },
    "panels": [
      {
        "title": "QPS (请求速率)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_server_requests_total{service=~\"$service\"}[5m])) by (route)",
            "legendFormat": "{{ route }}"
          }
        ]
      },
      {
        "title": "P50 / P95 / P99 延迟",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le, route))",
            "legendFormat": "P50 {{ route }}"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le, route))",
            "legendFormat": "P95 {{ route }}"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le, route))",
            "legendFormat": "P99 {{ route }}"
          }
        ]
      },
      {
        "title": "错误率 (5xx)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_server_requests_total{service=~\"$service\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_total{service=~\"$service\"}[5m]))",
            "legendFormat": "5xx 错误率"
          }
        ]
      },
      {
        "title": "并发请求数",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(http_server_inflight_requests{service=~\"$service\"}) by (service)",
            "legendFormat": "{{ service }}"
          }
        ]
      },
      {
        "title": "错误码分布",
        "type": "table",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "topk(20, sum(increase(http_server_error_codes_total{service=~\"$service\"}[1h])) by (error_code, module, kind))",
            "format": "table",
            "instant": true
          }
        ]
      }
    ]
  }
}
