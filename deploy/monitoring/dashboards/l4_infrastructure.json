{
  "dashboard": {
    "title": "L4 — 基础设施",
    "uid": "qwq-l4-infra",
    "tags": ["quwoquan", "l4", "infrastructure"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "Goroutine 数",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "go_goroutines",
            "legendFormat": "{{ instance }}"
          }
        ]
      },
      {
        "title": "GC 暂停时间",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
        "targets": [
          {
            "expr": "rate(go_gc_duration_seconds_sum[5m])",
            "legendFormat": "GC 时间 {{ instance }}"
          }
        ]
      },
      {
        "title": "内存使用 (Heap)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
        "targets": [
          {
            "expr": "go_memstats_heap_alloc_bytes",
            "legendFormat": "Heap {{ instance }}"
          },
          {
            "expr": "go_memstats_heap_sys_bytes",
            "legendFormat": "Sys {{ instance }}"
          }
        ]
      },
      {
        "title": "进程 CPU 使用",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total[5m])",
            "legendFormat": "CPU {{ instance }}"
          }
        ]
      },
      {
        "title": "进程 FD / RSS",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "process_open_fds",
            "legendFormat": "Open FDs {{ instance }}"
          },
          {
            "expr": "process_resident_memory_bytes / 1024 / 1024",
            "legendFormat": "RSS (MB) {{ instance }}"
          }
        ]
      }
    ]
  }
}
