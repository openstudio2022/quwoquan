{
  "dashboard": {
    "title": "L3 — 推荐模型服务 (rec-model-service)",
    "uid": "qwq-l3-rec-model",
    "tags": ["quwoquan", "l3", "rec-model", "prometheus"],
    "timezone": "browser",
    "refresh": "30s",
    "templating": {
      "list": [
        {
          "name": "job",
          "type": "query",
          "query": "label_values(http_requests_total, job)",
          "refresh": 2,
          "hide": 0,
          "includeAll": true,
          "multi": true
        }
      ]
    },
    "panels": [
      {
        "title": "HTTP 请求速率 (by handler)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=~\"$job\"}[5m])) by (handler)",
            "legendFormat": "{{ handler }}"
          }
        ]
      },
      {
        "title": "HTTP 延迟 P50 / P95 / P99（全局 high-res）",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_highr_seconds_bucket{job=~\"$job\"}[5m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_highr_seconds_bucket{job=~\"$job\"}[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_highr_seconds_bucket{job=~\"$job\"}[5m])) by (le))",
            "legendFormat": "P99"
          }
        ]
      },
      {
        "title": "打分耗时 P50 / P95 / P99（by model_version）",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(rec_score_duration_seconds_bucket{job=~\"$job\"}[5m])) by (le, model_version))",
            "legendFormat": "P50 {{ model_version }}"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(rec_score_duration_seconds_bucket{job=~\"$job\"}[5m])) by (le, model_version))",
            "legendFormat": "P95 {{ model_version }}"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(rec_score_duration_seconds_bucket{job=~\"$job\"}[5m])) by (le, model_version))",
            "legendFormat": "P99 {{ model_version }}"
          }
        ]
      },
      {
        "title": "模型是否已加载 (rec_model_loaded)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "rec_model_loaded{job=~\"$job\"}",
            "legendFormat": "{{ model_version }}"
          }
        ]
      },
      {
        "title": "HTTP 5xx 错误率",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=~\"$job\",status=\"5xx\"}[5m])) / sum(rate(http_requests_total{job=~\"$job\"}[5m]))",
            "legendFormat": "5xx 占比"
          }
        ]
      },
      {
        "title": "业务请求 rec_requests_total 速率 (by endpoint)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "sum(rate(rec_requests_total{job=~\"$job\"}[5m])) by (endpoint)",
            "legendFormat": "{{ endpoint }}"
          }
        ]
      },
      {
        "title": "打分分布 P50 / P95（by model_version）",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(rec_score_value_bucket{job=~\"$job\"}[5m])) by (le, model_version))",
            "legendFormat": "P50 {{ model_version }}"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(rec_score_value_bucket{job=~\"$job\"}[5m])) by (le, model_version))",
            "legendFormat": "P95 {{ model_version }}"
          }
        ]
      }
    ]
  }
}
