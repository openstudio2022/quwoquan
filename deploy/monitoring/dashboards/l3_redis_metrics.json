{
  "dashboard": {
    "title": "L3 — Redis 指标",
    "uid": "qwq-l3-redis",
    "tags": ["quwoquan", "l3", "redis"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "Redis OPS 速率",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(redis_operations_total[5m])) by (scene, status)",
            "legendFormat": "{{ scene }} ({{ status }})"
          }
        ]
      },
      {
        "title": "Redis 延迟 P50/P95",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(redis_duration_seconds_bucket[5m])) by (le, scene))",
            "legendFormat": "P50 {{ scene }}"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(redis_duration_seconds_bucket[5m])) by (le, scene))",
            "legendFormat": "P95 {{ scene }}"
          }
        ]
      },
      {
        "title": "Redis 错误率",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(redis_operations_total{status=\"error\"}[5m])) by (scene) / sum(rate(redis_operations_total[5m])) by (scene)",
            "legendFormat": "{{ scene }} 错误率"
          }
        ]
      }
    ]
  }
}
