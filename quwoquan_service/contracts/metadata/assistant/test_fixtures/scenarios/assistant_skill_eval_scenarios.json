      "vertical expert review checklists for finance, health, public service and travel"
    ],
    "dimensions": [
      {
        "id": "streamNarrative",
        "weight": 2,
        "description": "过程叙事清楚说明理解、检索/处理、生成答案三个阶段，禁止泄漏内部协议或工具参数"
      },
      {
        "id": "retrievalGrounding",
        "weight": 2,
        "description": "需要外部事实时优先权威、区域相关、时效合适的来源，并能说明覆盖与缺口"
      },
      {
        "id": "answerCorrectness",
        "weight": 2,
        "description": "结论直接回应问题，事实不自相矛盾，垂类边界清楚"
      },
      {
        "id": "domainCompleteness",
        "weight": 1.5,
        "description": "覆盖该垂类的关键槽位、约束和用户目标，不遗漏高影响信息"
