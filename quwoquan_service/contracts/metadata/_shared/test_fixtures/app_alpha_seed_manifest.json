{
  "schemaVersion": "app-seed-manifest",
  "environment": "alpha",
  "description": "alpha 共享池双通道装载清单：默认 flutter run 走本地 mock fixture，同时同一 seedRef 也必须可写入服务测试存储。",
  "seedRefs": [
    {
      "domain": "assistant",
      "fixturePath": "assistant/test_fixtures/scenarios/assistant_scenarios.json",
      "refs": [
        "assistant_p0_core",
        "skill_management_core"
      ],
      "resetScope": "fixture_assistant_*",
      "targetStore": "alpha-local-mock+assistant-service:memory",
      "verifiedEndpoints": [
        "/v1/assistant/conversations",
        "/v1/assistant/skill-subscriptions"
      ],
      "deliveryChannels": [
        "app-fixture-json",
        "assistant-service:memory"
      ]
    },
    {
      "domain": "content",
      "fixturePath": "content/test_fixtures/scenarios/content_scenarios.json",
      "refs": [
        "content_discovery_core",
        "home_feed_core",
        "content_detail_core",
        "search_core",
        "publish_core"
      ],
      "resetScope": "fixture_content_*",
      "targetStore": "alpha-local-mock+content-service:test_store",
      "verifiedEndpoints": [
        "/v1/content/feed"
      ],
      "deliveryChannels": [
        "app-fixture-json",
        "content-service:test_store"
      ]
    },
    {
      "domain": "circle",
      "fixturePath": "social/circle/test_fixtures/scenarios/circle_scenarios.json",
      "refs": [
        "circle_core",
        "circle_home_feed_core",
        "circle_profile_core",
        "circle_group_chat_link_core"
      ],
      "resetScope": "fixture_circle_*",
      "targetStore": "alpha-local-mock+circle-service:test_store",
      "verifiedEndpoints": [
        "/v1/circles"
      ],
      "deliveryChannels": [
        "app-fixture-json",
        "circle-service:test_store"
      ]
    },
    {
      "domain": "chat",
      "fixturePath": "messages/chat/test_fixtures/scenarios/chat_scenarios.json",
      "refs": [
        "chat_core",
        "chat_settings_core",
        "chat_contacts_core",
        "chat_group_flow_core"
      ],
      "resetScope": "fixture_chat_*",
      "targetStore": "alpha-local-mock+chat-service:test_store",
      "verifiedEndpoints": [
        "/v1/chat/inbox"
      ],
      "deliveryChannels": [
        "app-fixture-json",
        "chat-service:test_store"
      ]
    },
    {
      "domain": "user",
      "fixturePath": "user/test_fixtures/scenarios/user_scenarios.json",
      "refs": [
        "user_profile_core",
        "persona_core",
        "profile_feed_core",
        "relationship_core",
        "settings_core"
      ],
      "resetScope": "fixture_user_*",
      "targetStore": "alpha-local-mock+user-service:test_store",
      "verifiedEndpoints": [
        "/v1/user/profile"
      ],
      "deliveryChannels": [
        "app-fixture-json",
        "user-service:test_store"
      ]
    },
    {
      "domain": "entity",
      "fixturePath": "entity/test_fixtures/scenarios/entity_scenarios.json",
      "refs": [
        "entity_homepage_core",
        "entity_claim_core",
        "entity_picker_core"
      ],
      "resetScope": "fixture_entity_*",
      "targetStore": "alpha-local-mock+entity-service:test_store",
      "verifiedEndpoints": [
        "/v1/entity/homepages"
      ],
      "deliveryChannels": [
        "app-fixture-json",
        "entity-service:test_store"
      ]
    },
    {
      "domain": "integration",
      "fixturePath": "integration/test_fixtures/scenarios/integration_scenarios.json",
      "refs": [
        "location_poi_core"
      ],
      "resetScope": "fixture_integration_*",
      "targetStore": "alpha-local-mock+integration-service:test_store",
      "verifiedEndpoints": [
        "/v1/integration/locations/pois"
      ],
      "deliveryChannels": [
        "app-fixture-json",
        "integration-service:test_store"
      ]
    },
    {
      "domain": "notification",
      "fixturePath": "notification/test_fixtures/scenarios/notification_scenarios.json",
      "refs": [
        "notification_core"
      ],
      "resetScope": "fixture_notification_*",
      "targetStore": "alpha-local-mock+notification-service:test_store",
      "verifiedEndpoints": [
        "/v1/app-messages"
      ],
      "deliveryChannels": [
        "app-fixture-json",
        "notification-service:test_store"
      ]
    },
    {
      "domain": "rtc",
      "fixturePath": "rtc/test_fixtures/scenarios/rtc_scenarios.json",
      "refs": [
        "rtc_core"
      ],
      "resetScope": "fixture_rtc_*",
      "targetStore": "alpha-local-mock+rtc-service:test_store",
      "verifiedEndpoints": [
        "/v1/rtc/calls"
      ],
      "deliveryChannels": [
        "app-fixture-json",
        "rtc-service:test_store"
      ]
    }
  ],
  "appAssets": {
    "alphaOnlyFixtureAllowlist": [
      "content/test_fixtures/scenarios/content_scenarios.json",
      "social/circle/test_fixtures/scenarios/circle_scenarios.json",
      "messages/chat/test_fixtures/scenarios/chat_scenarios.json",
      "user/test_fixtures/scenarios/user_scenarios.json",
      "entity/test_fixtures/scenarios/entity_scenarios.json",
      "integration/test_fixtures/scenarios/integration_scenarios.json",
      "notification/test_fixtures/scenarios/notification_scenarios.json",
      "rtc/test_fixtures/scenarios/rtc_scenarios.json",
      "assistant/test_fixtures/scenarios/assistant_scenarios.json"
    ]
  },
  "gateway": {
    "routes": []
  }
}
