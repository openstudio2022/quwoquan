{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GeoCatalogRow",
  "type": "object",
  "required": [
    "topic_id",
    "name",
    "normalized_name",
    "label_zh",
    "display_locale",
    "entity_type",
    "entity_type_label_zh",
    "wiki_title",
    "baike_item",
    "province",
    "prefecture",
    "tagRefs",
    "authority_status"
  ],
  "properties": {
    "topic_id": { "type": "string", "minLength": 1 },
    "raw_name": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "normalized_name": { "type": "string", "minLength": 1 },
    "label_zh": { "type": "string" },
    "label_en": { "type": "string" },
    "display_locale": { "type": "string", "enum": ["zh", "en", "mixed"] },
    "entity_type": { "type": "string", "minLength": 1 },
    "entity_type_label_zh": { "type": "string", "minLength": 1 },
    "wiki_title": { "type": "string", "minLength": 1 },
    "baike_item": { "type": "string", "minLength": 1 },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "core_tokens": { "type": "array", "items": { "type": "string" } },
    "region": { "type": "string" },
    "province": { "type": "string", "minLength": 1 },
    "prefecture": { "type": "string", "minLength": 1 },
    "district": { "type": "string" },
    "expected_region_keywords": { "type": "array", "items": { "type": "string" } },
    "tagRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "authority_status": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string" },
    "source_id": { "type": "string" },
    "center_lat": { "type": ["number", "null"] },
    "center_lon": { "type": ["number", "null"] },
    "ordinal": { "type": "string" },
    "parent_name_hint": { "type": "string" },
    "cluster_hints": { "type": "array", "items": { "type": "string" } },
    "admission_track_hint": { "type": "string" },
    "evidence_article_urls": { "type": "array", "items": { "type": "string" } },
    "evidence_independence_notes": { "type": "array", "items": { "type": "string" } },
    "conflict_check_status": { "type": "string" },
    "undeveloped_or_wild_access": { "type": "boolean" },
    "reject_reason": { "type": "string" }
  },
  "additionalProperties": true
}
