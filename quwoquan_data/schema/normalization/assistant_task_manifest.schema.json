{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AssistantTaskManifest",
  "description": "编程助手归一化/内容加工任务清单",
  "type": "object",
  "required": ["schemaVersion", "stage", "batchLabel", "status", "taskCount", "tasks"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^quwoquan_data\\.normalization\\.assistant_task_manifest$"
    },
    "batchLabel": { "type": "string" },
    "stage": {
      "type": "string",
      "enum": ["extract", "review", "authority", "escalate", "content_quality", "content_generate", "content_backfill"]
    },
    "status": {
      "type": "string",
      "enum": ["waiting_for_programming_assistant", "completed", "partial"]
    },
    "assistantCommand": { "type": "string" },
    "assistantCommandDoc": { "type": "string" },
    "specPath": { "type": "string" },
    "topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "taskCount": { "type": "integer", "minimum": 0 },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sourceRef", "inputPath", "expectedResultPath"],
        "properties": {
          "sourceRef": { "type": "string" },
          "sourceUrl": { "type": "string" },
          "sourceTitle": { "type": "string" },
          "inputPath": { "type": "string" },
          "expectedResultPath": { "type": "string" },
          "assistantCommand": { "type": "string" },
          "assistantCommandDoc": { "type": "string" },
          "inputSchemaPath": { "type": "string" },
          "outputSchemaPath": { "type": "string" },
          "processingSummary": { "type": "string" },
          "selfCheckCommands": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
