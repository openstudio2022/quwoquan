{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceExtractionInput",
  "type": "object",
  "required": [
    "schemaVersion",
    "sourceRef",
    "batchLabel",
    "sourceType",
    "sourceUrl",
    "sourceTitle",
    "sourceBodyText",
    "sourceMarkdownPath",
    "imageAssetRefs",
    "assetLocalPaths",
    "requiredOutputSchema"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "sourceRef": { "type": "string", "minLength": 1 },
    "batchLabel": { "type": "string", "minLength": 1 },
    "catalogTopicId": { "type": "string" },
    "catalogName": { "type": "string" },
    "entityContextRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entityId", "canonicalName", "entityType"],
        "properties": {
          "entityId": { "type": "string", "minLength": 1 },
          "canonicalName": { "type": "string", "minLength": 1 },
          "entityType": { "type": "string", "minLength": 1 },
          "aliases": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "sourceType": { "type": "string", "enum": ["article", "image"] },
    "sourceUrl": { "type": "string", "minLength": 1 },
    "sourceTitle": { "type": "string", "minLength": 1 },
    "sourceBodyText": { "type": "string", "minLength": 1 },
    "sourceMarkdownPath": { "type": "string", "minLength": 1 },
    "imageAssetRefs": { "type": "array", "items": { "type": "string" } },
    "assetLocalPaths": { "type": "array", "items": { "type": "string" } },
    "authorityHints": { "type": "object" },
    "regionHints": { "type": "object" },
    "catalogHints": { "type": "object" },
    "normalizationHints": { "type": "object" },
    "requiredOutputSchema": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
