    "sourceRef",
    "batchLabel",
    "sourceUrl",
    "sourceTitle",
    "sourceMarkdownPath",
    "extractInputPath",
    "extractResultPath",
    "extractInput",
    "extractResult",
    "requiredOutputSchema"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "sourceRef": { "type": "string", "minLength": 1 },
    "batchLabel": { "type": "string", "minLength": 1 },
    "sourceUrl": { "type": "string", "minLength": 1 },
    "sourceTitle": { "type": "string", "minLength": 1 },
    "sourceMarkdownPath": { "type": "string", "minLength": 1 },
    "extractInputPath": { "type": "string", "minLength": 1 },
    "extractResultPath": { "type": "string", "minLength": 1 },
    "extractInput": { "type": "object" },
    "extractResult": { "type": "object" },
    "requiredOutputSchema": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
