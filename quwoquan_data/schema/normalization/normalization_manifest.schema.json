{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NormalizationManifest",
  "type": "object",
  "required": ["schemaVersion", "batchLabel", "status", "artifacts"],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "batchLabel": { "type": "string", "minLength": 1 },
    "catalogPath": { "type": "string" },
    "commandsVersion": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "running", "ready", "failed"] },
    "artifacts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
