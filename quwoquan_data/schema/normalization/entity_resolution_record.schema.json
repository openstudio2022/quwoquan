{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EntityResolutionRecord",
  "type": "object",
  "required": [
    "schemaVersion",
    "sourceRefs",
    "catalogTopicIds",
    "mainEntity",
    "members",
    "rejectedMembers",
    "selectedContentAssets",
    "rejectedAssets",
    "normalizationStatus",
    "manualReviewRequired"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "sourceRefs": { "type": "array", "items": { "type": "string" } },
    "catalogTopicIds": { "type": "array", "items": { "type": "string" } },
    "mainEntity": {
      "type": "object",
      "required": ["canonicalZhHans", "entityType", "summary", "authorityStatus", "authorityRefs", "aliases"],
      "properties": {
        "canonicalZhHans": { "type": "string", "minLength": 1 },
        "entityType": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "authorityStatus": { "type": "string", "minLength": 1 },
        "authorityRefs": { "type": "array", "items": { "type": "string" } },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "admissionTrack": { "type": "string" },
        "conflictCheckStatus": { "type": "string" }
      },
      "additionalProperties": true
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["nameCanonicalZhHans", "memberRole", "evidenceRefs"],
        "properties": {
          "nameCanonicalZhHans": { "type": "string", "minLength": 1 },
          "memberRole": { "type": "string", "minLength": 1 },
          "ordinal": { "type": "string" },
          "catalogTopicIds": { "type": "array", "items": { "type": "string" } },
          "evidenceRefs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "rejectedMembers": { "type": "array", "items": { "type": "object" } },
    "rawPoiRefs": { "type": "array", "items": { "type": "string" } },
    "sourceResultRefs": { "type": "array", "items": { "type": "object" } },
    "selectedContentAssets": { "type": "array", "items": { "type": "object" } },
    "rejectedAssets": { "type": "array", "items": { "type": "object" } },
    "evidenceArticleUrls": { "type": "array", "items": { "type": "string" } },
    "evidenceIndependenceNotes": { "type": "array", "items": { "type": "string" } },
    "conflictCheckStatus": { "type": "string" },
    "normalizationStatus": { "type": "string", "minLength": 1 },
    "manualReviewRequired": { "type": "boolean" }
  },
  "additionalProperties": true
}
