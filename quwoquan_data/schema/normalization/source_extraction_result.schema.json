{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceExtractionResult",
  "type": "object",
  "required": [
    "schemaVersion",
    "sourceRef",
    "batchLabel",
    "sourceUrl",
    "sourceTitle",
    "sourceMarkdownPath",
    "mainEntityCandidates",
    "memberCandidates",
    "aliasCandidates",
    "imageDecisions",
    "extractionStatus"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "sourceRef": { "type": "string", "minLength": 1 },
    "batchLabel": { "type": "string", "minLength": 1 },
    "catalogTopicId": { "type": "string" },
    "sourceUrl": { "type": "string", "minLength": 1 },
    "sourceTitle": { "type": "string", "minLength": 1 },
    "sourceMarkdownPath": { "type": "string", "minLength": 1 },
    "language": { "type": "string" },
    "mainEntityCandidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["nameOriginal", "nameCanonicalZhHansCandidate", "entityTypeCandidate", "confidence"],
        "properties": {
          "nameOriginal": { "type": "string", "minLength": 1 },
          "nameCanonicalZhHansCandidate": { "type": "string", "minLength": 1 },
          "entityTypeCandidate": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0 },
          "evidenceSpans": { "type": "array", "items": { "type": "string" } },
          "reasoningSummary": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "memberCandidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["nameOriginal", "nameCanonicalZhHansCandidate", "memberRole", "confidence"],
        "properties": {
          "nameOriginal": { "type": "string", "minLength": 1 },
          "nameCanonicalZhHansCandidate": { "type": "string", "minLength": 1 },
          "belongsToMainCandidate": { "type": "string" },
          "memberRole": { "type": "string", "minLength": 1 },
          "ordinal": { "type": "string" },
          "evidenceSpans": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": true
      }
    },
    "aliasCandidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["alias", "targetMainCandidate", "aliasType", "confidence"],
        "properties": {
          "alias": { "type": "string", "minLength": 1 },
          "targetMainCandidate": { "type": "string", "minLength": 1 },
          "aliasType": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0 },
          "evidenceSpans": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "imageDecisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "assetId",
          "imageType",
          "usableAsEntityEvidence",
          "watermarkStatusCandidate",
          "rightsStatusCandidate"
        ],
        "properties": {
          "assetId": { "type": "string", "minLength": 1 },
          "assetSourceUrl": { "type": "string" },
          "assetLocalPath": { "type": "string" },
          "pageTitle": { "type": "string" },
          "imageType": {
            "type": "string",
            "enum": ["content_photo", "icon_logo", "map_diagram", "poster_cover", "decorative", "unknown"]
          },
          "usableAsEntityEvidence": { "type": "boolean" },
          "depictsEntityCandidates": { "type": "array", "items": { "type": "string" } },
          "watermarkStatusCandidate": {
            "type": "string",
            "enum": ["clean", "visible", "suspected", "unknown"]
          },
          "rightsStatusCandidate": {
            "type": "string",
            "enum": ["clear", "unclear", "restricted", "unknown"]
          },
          "selectionReason": { "type": "string" },
          "reasoningSummary": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "uncertainItems": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extractionStatus": { "type": "string", "enum": ["ready_for_review", "needs_review", "failed"] }
  },
  "additionalProperties": true
}
