{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceReviewResult",
  "type": "object",
  "required": [
    "schemaVersion",
    "sourceRef",
    "batchLabel",
    "sourceUrl",
    "sourceTitle",
    "reviewedAt",
    "acceptedMainEntities",
    "acceptedMembers",
    "acceptedAliases",
    "selectedContentAssets",
    "rejectedAssets",
    "rejectedItems",
    "conflictFlags",
    "needsAuthorityBackcheck",
    "reviewSummary"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "sourceRef": { "type": "string", "minLength": 1 },
    "batchLabel": { "type": "string", "minLength": 1 },
    "sourceUrl": { "type": "string", "minLength": 1 },
    "sourceTitle": { "type": "string", "minLength": 1 },
    "reviewedAt": { "type": "string", "minLength": 1 },
    "acceptedMainEntities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidateRef", "canonicalZhHans", "entityType"],
        "properties": {
          "candidateRef": { "type": "string", "minLength": 1 },
          "canonicalZhHans": { "type": "string", "minLength": 1 },
          "entityType": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" },
          "evidenceRefs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "acceptedMembers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidateRef", "nameCanonicalZhHans", "memberRole"],
        "properties": {
          "candidateRef": { "type": "string", "minLength": 1 },
          "nameCanonicalZhHans": { "type": "string", "minLength": 1 },
          "belongsToMainCandidate": { "type": "string" },
          "memberRole": { "type": "string", "minLength": 1 },
          "ordinal": { "type": "string" },
          "evidenceRefs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "acceptedAliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["alias", "targetMainCandidate", "aliasType"],
        "properties": {
          "alias": { "type": "string", "minLength": 1 },
          "targetMainCandidate": { "type": "string", "minLength": 1 },
          "aliasType": { "type": "string", "minLength": 1 },
          "evidenceRefs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "selectedContentAssets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assetId", "selectionReason"],
        "properties": {
          "assetId": { "type": "string", "minLength": 1 },
          "selectionReason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "rejectedAssets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assetId", "rejectionReason"],
        "properties": {
          "assetId": { "type": "string", "minLength": 1 },
          "rejectionReason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "rejectedItems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["itemRef", "rejectionReason"],
        "properties": {
          "itemRef": { "type": "string", "minLength": 1 },
          "rejectionReason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "conflictFlags": {
      "type": "object",
      "required": [
        "parallelNotSubordinate",
        "genericNameWithoutProof",
        "articleOnlyListsStops",
        "cannotInferParentFromText"
      ],
      "properties": {
        "parallelNotSubordinate": { "type": "boolean" },
        "genericNameWithoutProof": { "type": "boolean" },
        "articleOnlyListsStops": { "type": "boolean" },
        "cannotInferParentFromText": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "needsAuthorityBackcheck": { "type": "boolean" },
    "reviewSummary": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
