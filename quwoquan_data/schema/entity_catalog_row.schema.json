{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EntityCatalogRow",
  "type": "object",
  "required": ["schemaVersion", "entityId", "canonicalName", "entityType", "tagRefs", "extensions"],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "entityId": { "type": "string", "minLength": 1 },
    "canonicalName": { "type": "string", "minLength": 1 },
    "entityType": { "type": "string", "minLength": 1 },
    "authorityProfileRef": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "entityRef": { "type": "string" },
    "tagRefs": { "type": "array", "items": { "type": "string" } },
    "topicId": { "type": "string" },
    "source": { "type": "string" },
    "extensions": {
      "type": "object",
      "properties": {
        "labelZh": { "type": "string" },
        "labelEn": { "type": "string" },
        "displayLocale": { "type": "string" },
        "entityTypeLabelZh": { "type": "string" },
        "wikiTitle": { "type": "string" },
        "baikeItem": { "type": "string" },
        "rawName": { "type": "string" },
        "normalizedName": { "type": "string" },
        "province": { "type": "string" },
        "prefecture": { "type": "string" },
        "district": { "type": "string" },
        "expectedRegionKeywords": { "type": "array", "items": { "type": "string" } },
        "sceneTagRefs": { "type": "array", "items": { "type": "string" } },
        "categoryTagRefs": { "type": "array", "items": { "type": "string" } },
        "coreTokens": { "type": "array", "items": { "type": "string" } },
        "members": { "type": "array", "items": { "type": "object" } },
        "selectedContentAssets": { "type": "array", "items": { "type": "object" } },
        "rejectedAssets": { "type": "array", "items": { "type": "object" } },
        "sourceRefs": { "type": "array", "items": { "type": "string" } },
        "authorityStatus": { "type": "string" },
        "authorityRefs": { "type": "array", "items": { "type": "string" } },
        "admissionTrack": { "type": "string" },
        "evidenceArticleUrls": { "type": "array", "items": { "type": "string" } },
        "evidenceIndependenceNotes": { "type": "array", "items": { "type": "string" } },
        "conflictCheckStatus": { "type": "string" },
        "undevelopedOrWildAccess": { "type": "boolean" },
        "normalizationStatus": { "type": "string" },
        "manualReviewRequired": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
