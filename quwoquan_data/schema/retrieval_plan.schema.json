{
  "title": "RetrievalPlan",
  "type": "object",
  "required": [
    "schemaVersion",
    "generated_at",
    "batch_id",
    "round",
    "status",
    "query",
    "search_queries",
    "location",
    "location_search_name",
    "target_domains",
    "missing_entity_refs",
    "missing_tag_refs",
    "planner_prompt"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "generated_at": { "type": "string" },
    "batch_id": { "type": "string" },
    "round": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["planned", "awaiting_collection", "ready_for_finalize", "completed", "exhausted"]
    },
    "query": { "type": "string" },
    "location": { "type": "string" },
    "location_search_name": { "type": "string" },
    "target_domains": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missing_entity_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missing_tag_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "planner_prompt": { "type": "string" },
    "stop_reason": { "type": "string" },
    "search_queries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "dimension",
          "query",
          "purpose",
          "execution_purpose",
          "round",
          "status",
          "target_domains",
          "entity_refs",
          "tag_refs"
        ],
        "properties": {
          "dimension": { "type": "string" },
          "query": { "type": "string" },
          "purpose": { "type": "string" },
          "execution_purpose": {
            "type": "string",
            "enum": ["source_page", "image_asset", "fact_gap", "layout_reference"]
          },
          "round": { "type": "integer", "minimum": 1 },
          "status": {
            "type": "string",
            "enum": ["pending", "done", "skipped"]
          },
          "target_domains": {
            "type": "array",
            "items": { "type": "string" }
          },
          "entity_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tag_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
