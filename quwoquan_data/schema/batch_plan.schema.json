{
  "title": "BatchPlan",
  "type": "object",
  "required": [
    "batch_id",
    "query",
    "search_provider",
    "allow_domains",
    "fetch_top_k",
    "expansion_rounds",
    "content_type_ref",
    "creator_refs",
    "entity_refs",
    "tag_refs",
    "target_envs",
    "publish_policy"
  ],
  "properties": {
    "batch_id": { "type": "string" },
    "query": { "type": "string" },
    "search_provider": {
      "type": "string",
      "enum": ["cursor_commands"]
    },
    "allow_domains": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fetch_top_k": { "type": "integer", "minimum": 1 },
    "expansion_rounds": { "type": "integer", "minimum": 1 },
    "content_type_ref": { "type": "string" },
    "creator_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "entity_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tag_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target_envs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["alpha", "beta", "gamma", "prod"]
      }
    },
    "retrieval_context": {
      "type": "object",
      "properties": {
        "location": { "type": "string" },
        "location_search_name": { "type": "string" }
      }
    },
    "completion_policy": {
      "type": "object",
      "properties": {
        "min_fact_count": { "type": "integer", "minimum": 1 },
        "min_evidence_urls": { "type": "integer", "minimum": 1 },
        "min_perspective_count": { "type": "integer", "minimum": 1 },
        "no_new_query_stop_rounds": { "type": "integer", "minimum": 1 }
      }
    },
    "post_package_policy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "require_source_markdown": { "type": "boolean" },
        "require_asset_manifest": { "type": "boolean" },
        "allow_referenced_only_assets": { "type": "boolean" }
      }
    },
    "publish_policy": {
      "type": "object",
      "required": ["visibility", "assistant_use_policy"],
      "properties": {
        "visibility": { "type": "string" },
        "assistant_use_policy": { "type": "string" }
      }
    }
  }
}
