{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourcePoolRow",
  "type": "object",
  "required": [
    "candidateId",
    "sourceId",
    "taskType",
    "topicTitle",
    "sourceUrl",
    "sourceRole",
    "rightsStatus",
    "watermarkStatus"
  ],
  "properties": {
    "candidateId": { "type": "string", "minLength": 1 },
    "sourceId": { "type": "string", "minLength": 1 },
    "taskType": { "type": "string", "enum": ["article", "image"] },
    "topicTitle": { "type": "string", "minLength": 1 },
    "query": { "type": "string" },
    "title": { "type": "string" },
    "sourceUrl": { "type": "string", "minLength": 1 },
    "snippet": { "type": "string" },
    "sourceRole": { "type": "string", "minLength": 1 },
    "rightsStatus": { "type": "string", "minLength": 1 },
    "watermarkStatus": { "type": "string", "minLength": 1 },
    "selectionDecision": { "type": "string" },
    "selectionBucket": { "type": "string" },
    "selectionReason": { "type": "string" },
    "qualityScore": { "type": "number" },
    "publishabilityScore": { "type": "number" },
    "imageQualityScore": { "type": "number" },
    "relevanceTokens": { "type": "array", "items": { "type": "string" } },
    "topicStrongTokens": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
