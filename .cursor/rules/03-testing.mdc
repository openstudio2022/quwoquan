app_name: quwoquan
android:
  app_id: com.quwoquan.app
  wait_for_app_launch_timeout: 30
ios:
  bundle_id: com.quwoquan.app
  wait_for_app_launch_timeout: 30
test_timeout: 120
retry: 1        # 允许 flaky 重试 1 次
