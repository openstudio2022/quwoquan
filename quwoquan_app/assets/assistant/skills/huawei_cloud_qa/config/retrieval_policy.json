{
  "contractVersion": "retrieval_policy_v1",
  "domainId": "huawei_cloud_qa",
  "allowedTimeScopes": [
    "latest",
    "today",
    "last_7d",
    "last_30d",
    "last_1y",
    "custom",
    "unspecified"
  ],
  "defaultTimeScope": "last_30d",
  "authorityRequired": true,
  "authorityDomains": [
    "huaweicloud.com",
    "support.huaweicloud.com",
    "bbs.huaweicloud.com",
    "developer.huaweicloud.com"
  ],
  "fallbackDomains": [
    "infoq.cn",
    "csdn.net",
    "juejin.cn",
    "36kr.com",
    "cloud.tencent.com",
    "aliyun.com",
    "aws.amazon.com",
    "azure.microsoft.com"
  ],
  "contextConstraints": [
    "产品名称",
    "服务阶段",
    "问题层级",
    "事实来源",
    "更新时间",
    "定价时效"
  ],
  "searchStrategies": {
    "L1": {
      "scope": "single_doc",
      "maxFragments": 5,
      "sitePriority": ["huaweicloud.com"],
      "expansion": ["synonym", "alias"]
    },
    "L2": {
      "scope": "multi_doc",
      "maxFragments": 15,
      "sitePriority": ["huaweicloud.com", "support.huaweicloud.com"],
      "expansion": ["keyword_variant", "related_product", "competitor_official"]
    },
    "L3": {
      "scope": "pricing_case_trend",
      "maxFragments": 10,
      "sitePriority": ["huaweicloud.com"],
      "expansion": ["historical_case", "pricing_doc"]
    },
    "L4": {
      "scope": "solution_architecture",
      "maxFragments": 15,
      "sitePriority": ["huaweicloud.com", "developer.huaweicloud.com"],
      "expansion": ["industry_solution", "migration_case", "best_practice"]
    }
  }
}
