{
  "catalogId": "assistant.tool_catalog",
  "version": "2026.03.06",
  "sourceModel": "mcp-like-tool-catalog",
  "tools": [
    {
      "toolName": "web_search",
      "displayName": "网络搜索",
      "purpose": "网络检索最新公开信息",
      "whenToUse": [
        "需要实时信息",
        "需要公开来源证据"
      ],
      "supportedSkills": [
        "retrieval.web",
        "evidence.freshness_check"
      ],
      "userInteraction": {
        "phaseTitle": "搜索资料",
        "phaseIcon": "search",
        "reasoning": {
          "label": "搜索策略设计",
          "promptHint": "请在 thinkingText 中用自然语言向用户解释：1. 为什么需要搜索 2. 你设计的搜索关键词及理由 3. 你期望找到什么信息",
          "example": "用户询问深圳天气，这是一个实时天气查询。我将搜索'深圳 实时天气 今天'和'深圳 天气预报'来获取权威气象数据。"
        },
        "executing": {
          "startLabel": "正在搜索相关资料",
          "progressTemplate": "检索查询：{{query}}",
          "completedTemplate": "已找到 {{referenceCount}} 篇相关资料"
        },
        "resultDisplay": {
          "showKeywords": true,
          "showReferences": true,
          "referenceCountPath": "references.length",
          "referenceTitlePath": "references[].title",
          "referenceSourcePath": "references[].source"
        },
        "replanLabel": "补充搜索更多资料"
      },
      "parameterSummary": [
        {"name": "query", "type": "string", "required": true, "description": "查询文本"},
        {"name": "provider", "type": "string", "required": false, "description": "搜索引擎"},
        {"name": "count", "type": "integer", "required": false, "description": "结果条数"},
        {"name": "domainId", "type": "string", "required": false, "description": "当前垂类ID，用于自动选择权威来源"},
        {"name": "contextConstraints", "type": "array<string>", "required": false, "description": "垂类上下文限定词"},
        {"name": "timeScope", "type": "string", "required": false, "description": "时间范围语义，如 latest/today/last_30d/year_to_date/year/year_month/year_month_day"},
        {"name": "timeYear", "type": "integer", "required": false, "description": "年份槽位，如 2024"},
        {"name": "timeMonth", "type": "integer", "required": false, "description": "月份槽位，1-12"},
        {"name": "timeDay", "type": "integer", "required": false, "description": "日期槽位，1-31"},
        {"name": "timePoint", "type": "string", "required": false, "description": "可选时间锚点，支持 YYYY / YYYY-MM / YYYY-MM-DD"},
        {"name": "timeRangeStart", "type": "string", "required": false, "description": "时间窗起点 ISO8601"},
        {"name": "timeRangeEnd", "type": "string", "required": false, "description": "时间窗终点 ISO8601"},
        {"name": "freshnessHoursMax", "type": "integer", "required": false, "description": "允许最大时效小时数"},
        {"name": "authorityDomains", "type": "array<string>", "required": false, "description": "权威来源域名白名单"}
      ],
      "requiredOutputPaths": ["provider", "summary", "references"],
      "openAiFunction": {
        "name": "web_search",
        "description": "网络检索最新信息。",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {"type": "string"},
            "provider": {"type": "string"},
            "count": {"type": "integer"},
            "domainId": {"type": "string"},
            "contextConstraints": {
              "type": "array",
              "items": {"type": "string"}
            },
            "timeScope": {"type": "string"},
            "timeYear": {"type": "integer"},
            "timeMonth": {"type": "integer"},
            "timeDay": {"type": "integer"},
            "timePoint": {"type": "string"},
            "timeRangeStart": {"type": "string"},
            "timeRangeEnd": {"type": "string"},
            "freshnessHoursMax": {"type": "integer"},
            "authorityDomains": {
              "type": "array",
              "items": {"type": "string"}
            }
          },
          "required": ["query"]
        }
      }
    },
    {
      "toolName": "local_context",
      "displayName": "本地上下文",
      "purpose": "获取设备上下文与地理位置信息（不包含相册数据）",
      "whenToUse": [
        "需要设备态信息",
        "需要城市或位置信息"
      ],
      "supportedSkills": [
        "device.context"
      ],
      "userInteraction": {
        "phaseTitle": "获取位置",
        "phaseIcon": "location",
        "reasoning": {
          "label": "位置获取",
          "promptHint": "请在 thinkingText 中向用户解释：你需要获取用户当前位置来精准回答问题",
          "example": "为了查询您所在城市的天气，我需要获取您的位置信息。"
        },
        "executing": {
          "startLabel": "正在获取您的位置",
          "progressTemplate": "读取设备信息...",
          "completedTemplate": "已定位到 {{city}}"
        },
        "resultDisplay": {
          "showKeywords": false,
          "showReferences": false,
          "summaryPath": "city"
        },
        "replanLabel": null
      },
      "parameterSummary": [
        {"name": "requestedFields", "type": "array<string>", "required": false, "description": "按需请求字段，例如 location permissions device"},
        {"name": "needPreciseLocation", "type": "boolean", "required": false, "description": "是否请求高精度位置"},
        {"name": "maxAgeSeconds", "type": "integer", "required": false, "description": "可接受的缓存秒数"}
      ],
      "responseSummary": [
        {"name": "contextVersion", "type": "string", "description": "上下文契约版本，固定 local_context_v1"},
        {"name": "city", "type": "string", "description": "当前城市"},
        {"name": "location", "type": "object", "description": "位置对象，含经纬度与精度"},
        {"name": "permissions", "type": "object", "description": "权限状态对象"},
        {"name": "device", "type": "object", "description": "设备信息对象"},
        {"name": "media.included", "type": "boolean", "description": "是否包含相册数据，固定 false"}
      ],
      "requiredOutputPaths": ["contextVersion", "location", "permissions", "media.included"],
      "openAiFunction": {
        "name": "local_context",
        "description": "获取设备本地上下文和地理位置信息。注意：不包含相册内容，相册请使用 media_gallery。",
        "parameters": {
          "type": "object",
          "properties": {
            "requestedFields": {
              "type": "array",
              "items": {"type": "string"},
              "description": "按需请求字段: location, permissions, device"
            },
            "needPreciseLocation": {
              "type": "boolean",
              "description": "是否请求高精度位置"
            },
            "maxAgeSeconds": {
              "type": "integer",
              "description": "可接受的缓存秒数"
            }
          }
        }
      }
    },
