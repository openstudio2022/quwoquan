          "example": "搜索结果中有一篇气象局的详细预报，我来仔细阅读获取精确数据。"
        },
        "executing": {
          "startLabel": "正在阅读网页内容",
          "progressTemplate": "抓取：{{url}}",
          "completedTemplate": "已阅读 {{charCount}} 字内容"
        },
        "resultDisplay": {
          "showKeywords": false,
          "showReferences": false,
          "summaryPath": "title"
        },
        "replanLabel": "阅读更多来源"
      },
      "parameterSummary": [
        {"name": "url", "type": "string", "required": true, "description": "要抓取的 URL"},
        {"name": "maxChars", "type": "integer", "required": false, "description": "最大字符数，默认 10000"}
      ],
      "requiredOutputPaths": ["url", "content"],
      "openAiFunction": {
        "name": "web_fetch",
        "description": "抓取指定 URL 的网页内容，提取正文转换为可读文本。适用于深入阅读搜索结果中的具体页面。",
        "parameters": {
          "type": "object",
          "properties": {
            "url": {"type": "string", "description": "要抓取的完整 URL（http/https）"},
            "maxChars": {"type": "integer", "description": "最大返回字符数，默认 10000"}
          },
          "required": ["url"]
        }
      }
    },
