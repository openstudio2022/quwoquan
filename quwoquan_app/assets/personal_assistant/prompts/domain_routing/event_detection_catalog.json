{
  "catalogId": "personal_assistant.event_detection_catalog",
  "version": "2026.02.20",
  "defaultEvent": "E_USER_QUERY_RECEIVED",
  "emptyTextEvent": "E_USER_REQUEST_EXPLAIN",
  "globalRules": [
    {
      "event": "E_USER_END_DIALOGUE",
      "priority": 100,
      "keywords": ["结束", "先到这里", "不聊了", "今天就到这"]
    },
    {
      "event": "E_USER_ACCEPT_ENRICH",
      "priority": 90,
      "keywords": ["愿意补充", "可以补充", "我可以补充"]
    },
    {
      "event": "E_USER_SKIP_ENRICH",
      "priority": 89,
      "keywords": ["不补", "算了", "直接说", "先不补"]
    },
    {
      "event": "E_USER_REQUEST_ACTION_PLAN",
      "priority": 70,
      "keywords": ["行动计划", "可执行", "怎么做"]
    },
    {
      "event": "E_USER_REQUEST_EXPLAIN",
      "priority": 60,
      "keywords": ["解释", "为什么", "如何判断"]
    },
    {
      "event": "E_USER_ADD_INFO",
      "priority": 50,
      "keywords": ["最近", "补充", "希望", "担心", "预算", "时间"]
    }
  ],
  "domainRules": {
    "divination_fortune": [
      {
        "event": "E_USER_FEEDBACK_PROGRESS",
        "priority": 95,
        "keywords": ["复盘", "执行了", "照做了", "反馈"],
        "stateBeforeIn": ["S4_DIALOGUE_LOOP_QA", "S5_FOLLOWUP_REVIEW"]
      }
    ],
    "work_productivity": [
      {
        "event": "E_USER_FEEDBACK_PROGRESS",
        "priority": 92,
        "keywords": ["复盘", "执行结果", "里程碑进展"],
        "stateBeforeIn": ["S4_FOLLOWUP_QA", "S5_SAFE_CLOSE"]
      }
    ]
  }
}
