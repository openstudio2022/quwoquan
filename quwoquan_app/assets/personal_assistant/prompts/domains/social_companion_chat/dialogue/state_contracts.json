{
  "contractSetId": "social_companion_chat.dialogue_state_contracts",
  "version": "2026.02.20",
  "domainId": "social_companion_chat",
  "globalRules": {
    "totalSubtotalFormat": {
      "requiredSections": ["总结", "分析", "建议", "下一步（可选）"],
      "description": "用户可见输出必须采用总分总格式"
    },
    "whitelistSites": [],
    "whitelistBoundaryNote": "本域白名单可为空；以自然对话为主。若涉及事实性话题可引用可信来源，但非强制。不得引用不可追溯、虚假或不当来源。",
    "requiredBoundaries": ["仅供闲聊陪伴", "深度情感请转专业支持"],
    "requiredCommonFields": ["evidence", "missingContextSlots", "fillGuidance", "followupPrompt", "toolCalls", "tracking"],
    "routingBoundary": "深度情感或危机类诉求必须路由至 emotion_companion，不得留在本域"
  },
  "evaluationPolicy": {
    "weightedScoringEnabled": false,
    "scoreItems": ["transitionAccuracyScore", "contractCompletenessScore", "globalRuleComplianceScore", "safetyBoundaryScore", "reasoningTraceabilityScore", "actionabilityScore", "dialogueExperienceScore"],
    "passThresholdPerItem": 80,
    "criticalScoreItems": ["transitionAccuracyScore", "globalRuleComplianceScore", "safetyBoundaryScore"],
    "criticalPassThresholdPerItem": 90,
    "manualSpotCheckRatio": 1
  },
  "transitions": [
    {"from": "S0_ENTRY_INTENT_CAPTURE", "event": "E_USER_QUERY_RECEIVED", "to": "S1_FAST_BASELINE_ANSWER"},
    {"from": "S1_FAST_BASELINE_ANSWER", "event": "E_USER_ACCEPT_ENRICH", "to": "S2_OPTIONAL_SLOT_ENRICHMENT"},
    {"from": "S1_FAST_BASELINE_ANSWER", "event": "E_USER_SKIP_ENRICH", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S1_FAST_BASELINE_ANSWER", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S2_OPTIONAL_SLOT_ENRICHMENT", "event": "E_USER_ADD_INFO", "to": "S3_PERSONALIZED_CHAT"},
    {"from": "S2_OPTIONAL_SLOT_ENRICHMENT", "event": "E_USER_SKIP_ENRICH", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S2_OPTIONAL_SLOT_ENRICHMENT", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S3_PERSONALIZED_CHAT", "event": "E_USER_REQUEST_EXPLAIN", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S3_PERSONALIZED_CHAT", "event": "E_USER_REQUEST_ACTION_PLAN", "to": "S5_FOLLOWUP_REVIEW"},
    {"from": "S4_DIALOGUE_LOOP_QA", "event": "E_USER_ADD_INFO", "to": "S3_PERSONALIZED_CHAT"},
    {"from": "S4_DIALOGUE_LOOP_QA", "event": "E_USER_FEEDBACK_PROGRESS", "to": "S5_FOLLOWUP_REVIEW"},
    {"from": "S4_DIALOGUE_LOOP_QA", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S5_FOLLOWUP_REVIEW", "event": "E_USER_REQUEST_EXPLAIN", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S5_FOLLOWUP_REVIEW", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S6_SAFE_CLOSE", "event": "E_USER_QUERY_RECEIVED", "to": "S0_ENTRY_INTENT_CAPTURE"}
  ],
  "stateContracts": {
    "S0_ENTRY_INTENT_CAPTURE": {
      "required": ["stateId", "intentSummary", "detectedIntentType", "userGoalGuess", "responseText", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S0_ENTRY_INTENT_CAPTURE"},
        "intentSummary": {"type": "string", "minLength": 1},
        "detectedIntentType": {"type": "string", "enum": ["chitchat", "topic_explore", "role_play", "daily_share", "mixed", "unknown"]},
        "userGoalGuess": {"type": "string"},
        "responseText": {"type": "string"},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S1_FAST_BASELINE_ANSWER"]}}
      }
    },
    "S1_FAST_BASELINE_ANSWER": {
      "required": ["stateId", "baselineAnswer", "evidence", "missingContextSlots", "fillGuidance", "followupPrompt", "toolCalls", "tracking", "safetyBoundary", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S1_FAST_BASELINE_ANSWER"},
        "baselineAnswer": {"type": "object", "required": ["summary", "response", "topicExtensions"]},
        "evidence": {"type": "array"},
        "missingContextSlots": {"type": "array"},
        "fillGuidance": {"type": "array"},
        "followupPrompt": {"type": "string"},
        "toolCalls": {"type": "array"},
        "tracking": {"type": "object"},
        "safetyBoundary": {"type": "object", "required": ["chitchatOnly", "deepEmotionRouteToEmotionCompanion"]},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S2_OPTIONAL_SLOT_ENRICHMENT", "S4_DIALOGUE_LOOP_QA", "S6_SAFE_CLOSE"]}}
      }
    },
    "S2_OPTIONAL_SLOT_ENRICHMENT": {
      "required": ["stateId", "slotStatus", "missingContextSlots", "fillGuidance", "optionalQuestions", "skipAllowed", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S2_OPTIONAL_SLOT_ENRICHMENT"},
        "slotStatus": {"type": "object"},
        "missingContextSlots": {"type": "array"},
        "fillGuidance": {"type": "array"},
        "optionalQuestions": {"type": "array", "minItems": 1, "maxItems": 2},
        "skipAllowed": {"type": "boolean", "const": true},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S3_PERSONALIZED_CHAT", "S4_DIALOGUE_LOOP_QA", "S6_SAFE_CLOSE"]}}
      }
    },
    "S3_PERSONALIZED_CHAT": {
      "required": ["stateId", "personalizedAnswer", "evidence", "missingContextSlots", "fillGuidance", "followupPrompt", "toolCalls", "tracking", "selfCheck", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S3_PERSONALIZED_CHAT"},
        "personalizedAnswer": {"type": "object", "required": ["summary", "response", "topicExtensions"]},
        "evidence": {"type": "array"},
        "missingContextSlots": {"type": "array"},
        "fillGuidance": {"type": "array"},
        "followupPrompt": {"type": "string"},
        "toolCalls": {"type": "array"},
        "tracking": {"type": "object"},
        "selfCheck": {"type": "object", "required": ["chitchatOnly", "deepEmotionRouteToEmotionCompanion", "missingItems"]},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S4_DIALOGUE_LOOP_QA", "S5_FOLLOWUP_REVIEW", "S6_SAFE_CLOSE"]}}
      }
    },
    "S4_DIALOGUE_LOOP_QA": {
      "required": ["stateId", "currentReply", "carryOverContext", "evidence", "missingContextSlots", "fillGuidance", "followupPrompt", "toolCalls", "tracking", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S4_DIALOGUE_LOOP_QA"},
        "currentReply": {"type": "string"},
        "carryOverContext": {"type": "object", "required": ["topic", "currentInterest", "openRisks"]},
        "evidence": {"type": "array"},
        "missingContextSlots": {"type": "array"},
        "fillGuidance": {"type": "array"},
        "followupPrompt": {"type": "string"},
        "toolCalls": {"type": "array"},
        "tracking": {"type": "object"},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S3_PERSONALIZED_CHAT", "S5_FOLLOWUP_REVIEW", "S6_SAFE_CLOSE"]}}
      }
    },
    "S5_FOLLOWUP_REVIEW": {
      "required": ["stateId", "reviewQuestions", "executionFeedbackSummary", "updatedChat", "adjustedPlans", "tracking", "nextCheckpoint", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S5_FOLLOWUP_REVIEW"},
        "reviewQuestions": {"type": "array", "minItems": 2, "maxItems": 3},
        "executionFeedbackSummary": {"type": "string"},
        "updatedChat": {"type": "object", "required": ["summary", "adjustedTopics"]},
        "adjustedPlans": {"type": "object", "required": ["avoidancePlan", "benefitPlan"]},
        "tracking": {"type": "object"},
        "nextCheckpoint": {"type": "string"},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S4_DIALOGUE_LOOP_QA", "S6_SAFE_CLOSE"]}}
      }
    },
    "S6_SAFE_CLOSE": {
      "required": ["stateId", "closingSummary", "nextOptionalActions", "boundaryStatement", "reopenHint"],
      "properties": {
        "stateId": {"type": "string", "const": "S6_SAFE_CLOSE"},
        "closingSummary": {"type": "string"},
        "nextOptionalActions": {"type": "array", "minItems": 2},
        "boundaryStatement": {"type": "string"},
        "reopenHint": {"type": "string"}
      }
    }
  }
}
