{
  "contractSetId": "fallback_general_search.dialogue_state_contracts",
  "version": "2026.02.20",
  "domainId": "fallback_general_search",
  "globalRules": {
    "onlineOfflineBoundaryRequired": true,
    "evidenceRecencyRequired": true,
    "evidenceRecencyOptions": ["实时", "近期（30天内）", "历史（30天前）", "无时效要求"],
    "timingWindows": ["近期", "近阶段", "后势", "逢节点"],
    "requiredBoundaries": ["基于当前知识边界", "如需最新权威信息请自行检索或咨询专业人士"],
    "allowedEvidenceSources": ["scholar.google.com", "arxiv.org", "wikipedia.org"],
    "recheckSuggestionRequired": true
  },
  "evaluationPolicy": {
    "weightedScoringEnabled": false,
    "scoreItems": [
      "transitionAccuracyScore",
      "contractCompletenessScore",
      "globalRuleComplianceScore",
      "safetyBoundaryScore",
      "reasoningTraceabilityScore",
      "actionabilityScore",
      "dialogueExperienceScore"
    ],
    "passThresholdPerItem": 80,
    "criticalScoreItems": [
      "transitionAccuracyScore",
      "globalRuleComplianceScore",
      "safetyBoundaryScore"
    ],
    "criticalPassThresholdPerItem": 90,
    "manualSpotCheckRatio": 1
  },
  "transitions": [
    {"from": "S0_ENTRY_INTENT_CAPTURE", "event": "E_USER_QUERY_RECEIVED", "to": "S1_FAST_BASELINE_ANSWER"},
    {"from": "S1_FAST_BASELINE_ANSWER", "event": "E_USER_ACCEPT_ENRICH", "to": "S2_OPTIONAL_SLOT_ENRICHMENT"},
    {"from": "S1_FAST_BASELINE_ANSWER", "event": "E_USER_SKIP_ENRICH", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S1_FAST_BASELINE_ANSWER", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S2_OPTIONAL_SLOT_ENRICHMENT", "event": "E_USER_ADD_INFO", "to": "S3_PERSONALIZED_REASONING"},
    {"from": "S2_OPTIONAL_SLOT_ENRICHMENT", "event": "E_USER_SKIP_ENRICH", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S2_OPTIONAL_SLOT_ENRICHMENT", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S3_PERSONALIZED_REASONING", "event": "E_USER_REQUEST_EXPLAIN", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S3_PERSONALIZED_REASONING", "event": "E_USER_REQUEST_ACTION_PLAN", "to": "S5_FOLLOWUP_REVIEW"},
    {"from": "S4_DIALOGUE_LOOP_QA", "event": "E_USER_ADD_INFO", "to": "S3_PERSONALIZED_REASONING"},
    {"from": "S4_DIALOGUE_LOOP_QA", "event": "E_USER_FEEDBACK_PROGRESS", "to": "S5_FOLLOWUP_REVIEW"},
    {"from": "S4_DIALOGUE_LOOP_QA", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S5_FOLLOWUP_REVIEW", "event": "E_USER_REQUEST_EXPLAIN", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S5_FOLLOWUP_REVIEW", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S6_SAFE_CLOSE", "event": "E_USER_QUERY_RECEIVED", "to": "S0_ENTRY_INTENT_CAPTURE"}
  ],
  "stateContracts": {
    "S0_ENTRY_INTENT_CAPTURE": {
      "required": ["stateId", "intentSummary", "detectedTopic", "onlineOfflineBoundary", "userGoalGuess", "responseText", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S0_ENTRY_INTENT_CAPTURE"},
        "intentSummary": {"type": "string", "minLength": 1},
        "detectedTopic": {"type": "string", "enum": ["fact_query", "open_exploration", "cross_domain", "unknown"]},
        "onlineOfflineBoundary": {"type": "object", "required": ["judgment", "reason"]},
        "userGoalGuess": {"type": "string"},
        "responseText": {"type": "string"},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S1_FAST_BASELINE_ANSWER"]}}
      }
    },
    "S1_FAST_BASELINE_ANSWER": {
      "required": ["stateId", "baselineAnswer", "onlineOfflineBoundary", "evidenceRecency", "knowledgeBoundary", "avoidanceHints", "benefitHints", "recheckSuggestion", "nonMandatoryPrompt", "safetyBoundary", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S1_FAST_BASELINE_ANSWER"},
        "baselineAnswer": {"type": "object", "required": ["summary", "favorablePath", "adversePath", "turningCondition"]},
        "onlineOfflineBoundary": {"type": "object", "required": ["judgment", "reason"]},
        "evidenceRecency": {"type": "object", "required": ["recencyType", "disclaimer"]},
        "knowledgeBoundary": {"type": "string"},
        "avoidanceHints": {"type": "array", "minItems": 2},
        "benefitHints": {"type": "array", "minItems": 2},
        "recheckSuggestion": {"type": "object", "required": ["keywords", "recommendedSites", "strategy"]},
        "nonMandatoryPrompt": {"type": "string"},
        "safetyBoundary": {"type": "object", "required": ["knowledgeBoundaryDisclaimer", "recheckAdvice"]},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S2_OPTIONAL_SLOT_ENRICHMENT", "S4_DIALOGUE_LOOP_QA", "S6_SAFE_CLOSE"]}}
      }
    },
    "S2_OPTIONAL_SLOT_ENRICHMENT": {
      "required": ["stateId", "slotStatus", "askStrategy", "optionalQuestions", "skipAllowed", "whyTheseQuestions", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S2_OPTIONAL_SLOT_ENRICHMENT"},
        "slotStatus": {"type": "object"},
        "askStrategy": {"type": "object", "required": ["maxQuestionsThisTurn", "questionOrderRule"]},
        "optionalQuestions": {"type": "array", "minItems": 1, "maxItems": 2},
        "skipAllowed": {"type": "boolean", "const": true},
        "whyTheseQuestions": {"type": "string"},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S3_PERSONALIZED_REASONING", "S4_DIALOGUE_LOOP_QA", "S6_SAFE_CLOSE"]}}
      }
    },
    "S3_PERSONALIZED_REASONING": {
      "required": ["stateId", "personalizedAnswer", "reasoningChain", "evidence", "evidenceRecency", "recheckSuggestion", "avoidancePlan", "benefitPlan", "selfCheck", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S3_PERSONALIZED_REASONING"},
        "personalizedAnswer": {"type": "object", "required": ["summary", "userContextAlignment"]},
        "reasoningChain": {"type": "array", "minItems": 2},
        "evidence": {"type": "array", "minItems": 1},
        "evidenceRecency": {"type": "object", "required": ["recencyType", "disclaimer"]},
        "recheckSuggestion": {"type": "object", "required": ["keywords", "recommendedSites", "strategy"]},
        "avoidancePlan": {"type": "array", "minItems": 2},
        "benefitPlan": {"type": "array", "minItems": 2},
        "selfCheck": {"type": "object", "required": ["knowledgeBoundaryRespected", "actionable", "missingItems"]},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S4_DIALOGUE_LOOP_QA", "S5_FOLLOWUP_REVIEW", "S6_SAFE_CLOSE"]}}
      }
    },
    "S4_DIALOGUE_LOOP_QA": {
      "required": ["stateId", "currentReply", "carryOverContext", "singleFollowupQuestion", "optionalEnrichmentReminder", "recheckPrompt", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S4_DIALOGUE_LOOP_QA"},
        "currentReply": {"type": "string"},
        "carryOverContext": {"type": "object", "required": ["topic", "currentTrend", "openRisks", "evidenceRecency"]},
        "singleFollowupQuestion": {"type": "string"},
        "optionalEnrichmentReminder": {"type": "string"},
        "recheckPrompt": {"type": "string"},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S3_PERSONALIZED_REASONING", "S5_FOLLOWUP_REVIEW", "S6_SAFE_CLOSE"]}}
      }
    },
    "S5_FOLLOWUP_REVIEW": {
      "required": ["stateId", "reviewQuestions", "executionFeedbackSummary", "updatedAnswer", "adjustedRecheckSuggestion", "nextCheckpoint", "nextStateCandidates"],
      "properties": {
        "stateId": {"type": "string", "const": "S5_FOLLOWUP_REVIEW"},
        "reviewQuestions": {"type": "array", "minItems": 2, "maxItems": 3},
        "executionFeedbackSummary": {"type": "string"},
        "updatedAnswer": {"type": "object", "required": ["trendShift", "newEvidence", "evidenceRecency"]},
        "adjustedRecheckSuggestion": {"type": "object", "required": ["keywords", "recommendedSites", "strategy"]},
        "nextCheckpoint": {"type": "string"},
        "nextStateCandidates": {"type": "array", "items": {"type": "string", "enum": ["S4_DIALOGUE_LOOP_QA", "S6_SAFE_CLOSE"]}}
      }
    },
    "S6_SAFE_CLOSE": {
      "required": ["stateId", "closingSummary", "evidenceRecencyStatement", "recheckSuggestion", "nextOptionalActions", "boundaryStatement", "reopenHint"],
      "properties": {
        "stateId": {"type": "string", "const": "S6_SAFE_CLOSE"},
        "closingSummary": {"type": "string"},
        "evidenceRecencyStatement": {"type": "string"},
        "recheckSuggestion": {"type": "object"},
        "nextOptionalActions": {"type": "array", "minItems": 2},
        "boundaryStatement": {"type": "string"},
        "reopenHint": {"type": "string"}
      }
    }
  }
}
