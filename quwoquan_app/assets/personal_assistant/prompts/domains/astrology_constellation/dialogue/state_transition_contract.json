{
  "contractId": "astrology_constellation.state_transition_eval_contract",
  "version": "2026.02.20",
  "domainId": "astrology_constellation",
  "scoreItems": [
    "transitionAccuracyScore",
    "contractCompletenessScore",
    "globalRuleComplianceScore",
    "safetyBoundaryScore",
    "reasoningTraceabilityScore",
    "actionabilityScore",
    "dialogueExperienceScore"
  ],
  "scoreRange": {"min": 0, "max": 100},
  "passThresholdPerItem": 80,
  "criticalScoreItems": [
    "transitionAccuracyScore",
    "globalRuleComplianceScore",
    "safetyBoundaryScore"
  ],
  "criticalPassThresholdPerItem": 90,
  "weightedScoringEnabled": false,
  "hardFailCodes": [
    "PERCENT_PROBABILITY_USED",
    "DETERMINISM_USED",
    "FORCED_ENRICHMENT",
    "BOUNDARY_MISSING",
    "ILLEGAL_TRANSITION"
  ],
  "globalRules": {
    "probabilityExpressionForbiddenPatterns": ["[0-9]{1,3}%", "百分之", "命中注定", "必然发生"],
    "enrichmentPolicy": {"mustBeOptional": true, "maxQuestionsPerTurn": 2},
    "requiredBoundaryStatements": ["仅供娱乐参考", "非决定论", "不替代专业建议"],
    "allowedEvidenceSources": ["astro.com", "cafeastrology.com", "astrology.com"],
    "timingWindowPolicy": {"baseVocabulary": ["近期", "近阶段", "后势", "逢节点"], "industryExtensionEnabled": true}
  },
  "qualityAssurance": {
    "manualSpotCheckRatio": 1,
    "manualSpotCheckTriggerRules": ["hardFailTriggered=true", "anyScoreItem<85", "newTemplateFirstBatch=true"]
  },
  "stateIds": [
    "S0_ENTRY_INTENT_CAPTURE",
    "S1_FAST_BASELINE_ANSWER",
    "S2_OPTIONAL_SLOT_ENRICHMENT",
    "S3_PERSONALIZED_REASONING",
    "S4_DIALOGUE_LOOP_QA",
    "S5_FOLLOWUP_REVIEW",
    "S6_SAFE_CLOSE"
  ],
  "events": [
    "E_USER_QUERY_RECEIVED",
    "E_USER_ACCEPT_ENRICH",
    "E_USER_SKIP_ENRICH",
    "E_USER_ADD_INFO",
    "E_USER_REQUEST_EXPLAIN",
    "E_USER_REQUEST_ACTION_PLAN",
    "E_USER_FEEDBACK_PROGRESS",
    "E_USER_END_DIALOGUE"
  ],
  "transitions": [
    {"from": "S0_ENTRY_INTENT_CAPTURE", "event": "E_USER_QUERY_RECEIVED", "to": "S1_FAST_BASELINE_ANSWER"},
    {"from": "S1_FAST_BASELINE_ANSWER", "event": "E_USER_ACCEPT_ENRICH", "to": "S2_OPTIONAL_SLOT_ENRICHMENT"},
    {"from": "S1_FAST_BASELINE_ANSWER", "event": "E_USER_SKIP_ENRICH", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S1_FAST_BASELINE_ANSWER", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S2_OPTIONAL_SLOT_ENRICHMENT", "event": "E_USER_ADD_INFO", "to": "S3_PERSONALIZED_REASONING"},
    {"from": "S2_OPTIONAL_SLOT_ENRICHMENT", "event": "E_USER_SKIP_ENRICH", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S2_OPTIONAL_SLOT_ENRICHMENT", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S3_PERSONALIZED_REASONING", "event": "E_USER_REQUEST_EXPLAIN", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S3_PERSONALIZED_REASONING", "event": "E_USER_REQUEST_ACTION_PLAN", "to": "S5_FOLLOWUP_REVIEW"},
    {"from": "S4_DIALOGUE_LOOP_QA", "event": "E_USER_ADD_INFO", "to": "S3_PERSONALIZED_REASONING"},
    {"from": "S4_DIALOGUE_LOOP_QA", "event": "E_USER_FEEDBACK_PROGRESS", "to": "S5_FOLLOWUP_REVIEW"},
    {"from": "S4_DIALOGUE_LOOP_QA", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S5_FOLLOWUP_REVIEW", "event": "E_USER_REQUEST_EXPLAIN", "to": "S4_DIALOGUE_LOOP_QA"},
    {"from": "S5_FOLLOWUP_REVIEW", "event": "E_USER_END_DIALOGUE", "to": "S6_SAFE_CLOSE"},
    {"from": "S6_SAFE_CLOSE", "event": "E_USER_QUERY_RECEIVED", "to": "S0_ENTRY_INTENT_CAPTURE"}
  ],
  "requiredFieldsByState": {
    "S0_ENTRY_INTENT_CAPTURE": ["stateId", "intentSummary", "detectedTopic", "responseText", "nextStateCandidates"],
    "S1_FAST_BASELINE_ANSWER": ["stateId", "baselineAnswer", "possibilityReading", "timingWindow", "avoidanceHints", "benefitHints", "nonMandatoryPrompt", "safetyBoundary", "nextStateCandidates"],
    "S2_OPTIONAL_SLOT_ENRICHMENT": ["stateId", "slotStatus", "optionalQuestions", "skipAllowed", "nextStateCandidates"],
    "S3_PERSONALIZED_REASONING": ["stateId", "personalizedAnswer", "reasoningChain", "evidence", "possibilityReading", "timingWindow", "avoidancePlan", "benefitPlan", "selfCheck", "nextStateCandidates"],
    "S4_DIALOGUE_LOOP_QA": ["stateId", "currentReply", "carryOverContext", "singleFollowupQuestion", "nextStateCandidates"],
    "S5_FOLLOWUP_REVIEW": ["stateId", "reviewQuestions", "executionFeedbackSummary", "updatedReading", "adjustedPlans", "nextCheckpoint", "nextStateCandidates"],
    "S6_SAFE_CLOSE": ["stateId", "closingSummary", "nextOptionalActions", "boundaryStatement", "reopenHint"]
  },
  "passCriteria": {
    "roundPass": {
      "noHardFail": true,
      "allScoreItemsAtLeast": 80,
      "criticalScoreItemsAtLeast": 90,
      "transitionMatched": true
    },
    "casePass": {
      "noHardFail": true,
      "coverageRatioEquals": 1,
      "allScoreItemsAtLeast": 80,
      "criticalScoreItemsAtLeast": 90
    },
    "suitePass": {
      "completionRatioAtLeast": 0.95,
      "hardFailCasesEquals": 0,
      "allScoreItemPassRateAtLeast": 0.95,
      "criticalScoreItemPassRateAtLeast": 0.95
    }
  }
}
