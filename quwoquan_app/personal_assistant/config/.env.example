PERSONAL_ASSISTANT_MIMO_API_KEY=replace_with_real_key
PERSONAL_ASSISTANT_MODEL_PROVIDER=mimo
PERSONAL_ASSISTANT_MODEL_ID=mimo-v2-flash
PERSONAL_ASSISTANT_MODEL_BASE_URL=https://api.xiaomimimo.com/v1
PERSONAL_ASSISTANT_MODEL_API_KEY=replace_with_real_key
PERSONAL_ASSISTANT_GATEWAY_TOKEN=replace_with_gateway_token
PERSONAL_ASSISTANT_ENABLE_MOLTBOT_COMPAT=false
PERSONAL_ASSISTENT_ENABLE_API=true

# Alert routing
ASSISTENT_ALERT_WEBHOOK_URL=
ASSISTENT_ALERT_FEISHU_WEBHOOK=
ASSISTENT_ALERT_SUPPRESS_SECONDS=180
ASSISTENT_ALERT_AUTO_DISABLE_MINUTES=10

# Signature policy
ASSISTENT_FEISHU_SIGN_MODE=hmac_sha256
ASSISTENT_FEISHU_SIGN_SECRET=replace_with_feishu_sign_secret
ASSISTENT_FEISHU_MAX_SKEW_SECONDS=300
ASSISTENT_OPENCLAW_SIGN_MODE=hmac_sha256
ASSISTENT_OPENCLAW_SIGN_SECRET=replace_with_openclaw_sign_secret
ASSISTENT_OPENCLAW_MAX_SKEW_SECONDS=300
