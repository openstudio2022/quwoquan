PERSONAL_ASSISTANT_MIMO_API_KEY=replace_with_real_key
PERSONAL_ASSISTANT_MODEL_PROVIDER=mimo
PERSONAL_ASSISTANT_MODEL_ID=mimo-v2-flash
PERSONAL_ASSISTANT_MODEL_BASE_URL=https://api.xiaomimimo.com/v1
PERSONAL_ASSISTANT_MODEL_API_KEY=replace_with_real_key
PERSONAL_ASSISTANT_GATEWAY_TOKEN=replace_with_gateway_token
PERSONAL_ASSISTANT_ENABLE_MOLTBOT_COMPAT=false
PERSONAL_ASSISTANT_ENABLE_API=true

# Alert routing
ASSISTANT_ALERT_WEBHOOK_URL=
ASSISTANT_ALERT_FEISHU_WEBHOOK=
ASSISTANT_ALERT_SUPPRESS_SECONDS=180
ASSISTANT_ALERT_AUTO_DISABLE_MINUTES=10

# Signature policy
ASSISTANT_FEISHU_SIGN_MODE=hmac_sha256
ASSISTANT_FEISHU_SIGN_SECRET=replace_with_feishu_sign_secret
ASSISTANT_FEISHU_MAX_SKEW_SECONDS=300
ASSISTANT_OPENCLAW_SIGN_MODE=hmac_sha256
ASSISTANT_OPENCLAW_SIGN_SECRET=replace_with_openclaw_sign_secret
ASSISTANT_OPENCLAW_MAX_SKEW_SECONDS=300
